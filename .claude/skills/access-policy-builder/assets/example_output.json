{
  "_example_meta": {
    "description": "两个示例：1.完全屏蔽（已限制模式）；2.可访问但限制操作（可访问模式）",
    "version": "2.1"
  },

  "examples": [
    {
      "user_request": "工作时间禁止员工访问视频网站，BOSS除外",
      "platform_capability_check": {
        "supported": true,
        "reason": "URL级页面屏蔽 + 按成员/时段生效"
      },

      "form_output": {
        "策略名称": "工作时间视频网站限制",
        "生效成员": "除BOSS外所有成员",
        "生效平台账号": "所有账号",
        "生效时段": {
          "模式": "指定时段生效",
          "生效日期": { "启用": false },
          "生效周期": { "启用": true, "选中": ["一", "二", "三", "四", "五"] },
          "生效时间": { "启用": true, "开始时间": "09:00", "结束时间": "18:00" }
        },
        "访问策略描述": "工作日9:00-18:00禁止访问视频网站（B站、爱奇艺、优酷、腾讯视频、芒果TV），BOSS不受限。防止工作时间浏览娱乐内容影响效率。",
        "访问审批限制": {
          "仅boss账号可审批": false,
          "不允许申请访问": false
        }
      },

      "tab_指定网页生效策略": [
        { "url_rule": "https://*.bilibili.com",  "mode": "已限制", "说明": "B站" },
        { "url_rule": "https://*.iqiyi.com",     "mode": "已限制", "说明": "爱奇艺" },
        { "url_rule": "https://*.youku.com",     "mode": "已限制", "说明": "优酷" },
        { "url_rule": "https://*.v.qq.com",      "mode": "已限制", "说明": "腾讯视频" },
        { "url_rule": "https://*.mgtv.com",      "mode": "已限制", "说明": "芒果TV" }
      ],

      "tab_所有网页通用策略": {
        "复制": "允许且记录",
        "文件上传": "允许且记录",
        "文件下载": "允许且记录",
        "打印": "允许且记录",
        "鼠标点击": "允许",
        "键盘输入": "允许",
        "查看密码框": "允许"
      }
    },

    {
      "user_request": "运营可以看账户详情页但不能复制内容、不能下载、不能截屏操作",
      "platform_capability_check": {
        "supported": true,
        "reason": "URL级页面可访问模式 + 操作行为控制"
      },

      "form_output": {
        "策略名称": "运营账户详情页只读限制",
        "生效成员": "指定成员：运营",
        "生效平台账号": "所有账号",
        "生效时段": {
          "模式": "一直生效",
          "生效日期": { "启用": false },
          "生效周期": { "启用": false },
          "生效时间": { "启用": false }
        },
        "访问策略描述": "运营可访问账户详情页但限制复制、下载、打印操作，防止敏感信息外泄。鼠标点击和键盘输入限制，仅允许查看。",
        "访问审批限制": {
          "仅boss账号可审批": false,
          "不允许申请访问": false
        }
      },

      "tab_指定网页生效策略": [
        {
          "url_rule": "https://*.amazon.*/sw/AccountInfo",
          "mode": "可访问",
          "说明": "所有站点账户详情页（通配符覆盖）",
          "behavior_controls": {
            "复制": "限制且记录",
            "文件上传": "限制且记录",
            "文件下载": "限制且记录",
            "打印": "限制且记录",
            "鼠标点击": "限制",
            "键盘输入": "限制",
            "查看密码框": "限制"
          }
        }
      ],

      "tab_所有网页通用策略": {
        "复制": "允许且记录",
        "文件上传": "允许且记录",
        "文件下载": "允许且记录",
        "打印": "允许且记录",
        "鼠标点击": "允许",
        "键盘输入": "允许",
        "查看密码框": "允许"
      }
    }
  ]
}
